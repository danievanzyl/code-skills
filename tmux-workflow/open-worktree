#!/usr/bin/env bash
# open-worktree — fzf picker over existing worktrees in current project.
# Opens a window for the selected worktree, or switches to it if already open.
set -euo pipefail

if [[ -z "${TMUX:-}" ]]; then
  echo "must be run inside a tmux session (sessionizer first)" >&2
  exit 1
fi

project=$(tmux display-message -p '#S')
REPO_BASE="${REPO_BASE:-$HOME/code/ritdu}"
project_dir="$REPO_BASE/$project"
src_dir="$project_dir/src"

if [[ ! -d "$src_dir" ]]; then
  echo "no src/ in $project_dir — is the session name a project dir under $REPO_BASE?" >&2
  exit 1
fi

selected=$(git -C "$src_dir" worktree list --porcelain \
  | awk '/^worktree / {print $2}' \
  | fzf --prompt='worktree> ' --height=40%)
[[ -z "$selected" ]] && exit 0

branch=$(basename "$selected")

if tmux list-windows -t "$project" -F '#W' 2>/dev/null | grep -qx "$branch"; then
  tmux select-window -t "$project:$branch"
  exit 0
fi

window_id=$(tmux new-window -t "$project:" -n "$branch" -c "$selected" -P -F '#{window_id}')

if [[ "$branch" == "src" ]]; then
  tmux split-window -h -l 40% -t "$window_id" -c "$selected"
  tmux split-window -v -t "$window_id" -c "$selected"
  tmux select-pane -t "$window_id" -L
else
  tmux split-window -h -l 40% -t "$window_id" -c "$selected"
  tmux split-window -v -t "$window_id" -c "$selected"
  tmux select-pane -t "$window_id" -L
  tmux send-keys -t "$window_id" "claude" Enter
fi

stamp_dir="$HOME/.cache/tmux-worktrees"
mkdir -p "$stamp_dir"
cat >"$stamp_dir/${window_id#@}" <<EOF
WORKTREE="$selected"
BRANCH="$branch"
PROJECT="$project"
EOF
