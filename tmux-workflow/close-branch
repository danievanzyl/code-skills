#!/usr/bin/env bash
# Two entry points:
#   close-branch              — manual (prefix-X), kills window after cleanup
#   close-branch <window-id>  — hook (window-unlinked), surfaces outcome via tmux display-message
set -euo pipefail

stamp_dir="$HOME/.cache/tmux-worktrees"

manual=0
if [[ -n "${1:-}" ]]; then
  window_id="${1#@}"
else
  manual=1
  if [[ -z "${TMUX:-}" ]]; then
    echo "not in tmux and no window-id given" >&2
    exit 1
  fi
  window_id=$(tmux display-message -p '#{window_id}')
  window_id="${window_id#@}"
fi

notify() {
  local level="$1"; shift
  local msg="$*"
  if [[ "$manual" == 1 ]]; then
    echo "$msg" >&2
  else
    # -d 5000ms for warnings, longer for errors so user has time to read
    local dur=5000
    [[ "$level" == "error" ]] && dur=8000
    tmux display-message -d "$dur" "[worktree] $msg" 2>/dev/null || true
  fi
}

stamp_file="$stamp_dir/$window_id"
[[ -f "$stamp_file" ]] || exit 0

# shellcheck source=/dev/null
. "$stamp_file"

if [[ "$WORKTREE" == */src ]]; then
  notify warn "refusing to delete main checkout"
  exit 0
fi

if ! state=$(gh pr view "$BRANCH" --json state -q .state 2>/dev/null); then
  notify warn "kept $BRANCH: no PR found (or gh unavailable)"
  exit 0
fi

if [[ "$state" != "MERGED" ]]; then
  notify warn "kept $BRANCH: PR is $state (not MERGED)"
  exit 0
fi

src_dir="$(dirname "$WORKTREE")/src"
if ! git -C "$src_dir" worktree remove --force "$WORKTREE" 2>/tmp/close-branch-err; then
  notify error "failed to remove $BRANCH: $(cat /tmp/close-branch-err)"
  exit 1
fi
rm -f "$stamp_file" /tmp/close-branch-err

notify warn "removed worktree $BRANCH"

if [[ "$manual" == 1 ]]; then
  tmux kill-window
fi
