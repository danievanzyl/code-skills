#!/usr/bin/env bash
set -euo pipefail

CODE_ROOT="${CODE_ROOT:-$HOME/code}"

toplevel="${1:-}"
if [[ -z "$toplevel" ]]; then
  toplevel=$(fd . "$CODE_ROOT" -td -d 1 -x basename | fzf --prompt='toplevel> ')
fi
[[ -z "$toplevel" ]] && exit 0

REPO_BASE="$CODE_ROOT/$toplevel"
if [[ ! -d "$REPO_BASE" ]]; then
  echo "no such dir: $REPO_BASE" >&2
  exit 1
fi

selected="${2:-}"
if [[ -z "$selected" ]]; then
  selected=$(fd . "$REPO_BASE" -td -d 1 | fzf --prompt="${toplevel}> ")
fi
[[ -z "$selected" ]] && exit 0

name=$(basename "$selected")
src_dir="$selected/src"

if [[ ! -d "$src_dir" ]]; then
  echo "no src/ in $selected" >&2
  exit 1
fi

if ! tmux has-session -t="$name" 2>/dev/null; then
  tmux new-session -ds "$name" -n src -c "$src_dir"
  tmux split-window -h -l 40% -t "$name:src" -c "$src_dir"
  tmux split-window -v -t "$name:src" -c "$src_dir"
  tmux select-pane -t "$name:src" -L
fi

tmux set-environment -t "$name" PROJECT_DIR "$selected"

if [[ -n "${TMUX:-}" ]]; then
  tmux switch-client -t "$name"
else
  tmux attach -t "$name"
fi
